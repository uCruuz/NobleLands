# Copie este arquivo para .env e preencha os valores
# NUNCA comite o arquivo .env no repositório

# Banco de dados PostgreSQL
DATABASE_URL=postgresql://postgres:SUA_SENHA_AQUI@localhost:5432/tribalwars

# Segredo JWT — gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GERE_UM_SEGREDO_FORTE_AQUI

# Origens permitidas no CORS (separadas por vírgula)
ALLOWED_ORIGINS=http://localhost:5173

# Porta do servidor (opcional, padrão: 9999)
PORT=9999
